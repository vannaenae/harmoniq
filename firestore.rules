rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isMemberOf(choirId) {
      return isSignedIn() && getUserData().choirId == choirId;
    }

    function isDirectorOf(choirId) {
      return isMemberOf(choirId) && getUserData().role == 'director';
    }

    // Returns true when the signed-in user may see a channel based on its
    // visibleTo field. Directors always see everything.
    function canSeeChannel(channelData) {
      let vis = channelData.visibleTo;
      let role = getUserData().role;
      let part = getUserData().voicePart;
      let vocalistParts = ['soprano', 'alto', 'tenor', 'bass', 'unclassified'];
      let instrumentParts = ['keys', 'guitar', 'bass_guitar', 'drums', 'other_instrument'];
      return vis == 'all'
        || role == 'director'
        || (vis == 'vocalists' && vocalistParts.hasAny([part]))
        || (vis == 'instrumentalists' && instrumentParts.hasAny([part]));
    }

    // Returns true when the signed-in user may post to a channel (directors
    // can always post; non-directors are blocked if directorOnly is true).
    function canPostToChannel(channelData) {
      return canSeeChannel(channelData)
        && (!channelData.directorOnly || getUserData().role == 'director');
    }

    function isChoirOwner(choirId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/choirs/$(choirId)).data.ownerId == request.auth.uid;
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if isSignedIn() && isOwner(uid);
      allow create: if isSignedIn() && isOwner(uid);
      allow update: if isSignedIn() && isOwner(uid);
      allow delete: if false; // handled by Cloud Function on account deletion
    }

    // ── Choirs ────────────────────────────────────────────────────────────────
    match /choirs/{choirId} {
      allow read:   if isMemberOf(choirId) || isChoirOwner(choirId);
      allow create: if isSignedIn();
      allow update: if isDirectorOf(choirId) || isChoirOwner(choirId);
      allow delete: if isChoirOwner(choirId);

      // Members subcollection
      match /members/{memberId} {
        allow read:  if isMemberOf(choirId) || isChoirOwner(choirId);
        allow write: if isDirectorOf(choirId) || isChoirOwner(choirId)
                     || (isSignedIn() && request.auth.uid == memberId); // joining
      }

      // Services subcollection
      match /services/{serviceId} {
        allow read:  if isMemberOf(choirId) || isChoirOwner(choirId);
        allow write: if isDirectorOf(choirId) || isChoirOwner(choirId);

        // Set list items
        match /setlist/{itemId} {
          allow read:  if isMemberOf(choirId) || isChoirOwner(choirId);
          allow write: if isDirectorOf(choirId) || isChoirOwner(choirId);
        }

        // Availability
        match /availability/{userId} {
          allow read:  if isMemberOf(choirId) || isChoirOwner(choirId);
          allow create: if isSignedIn() && request.auth.uid == userId;
          allow update: if isSignedIn() && request.auth.uid == userId;
        }

        // Attendance — members read (their own + choir-wide); Directors write.
        match /attendance/{userId} {
          allow read:  if isMemberOf(choirId) || isChoirOwner(choirId);
          allow write: if isDirectorOf(choirId) || isChoirOwner(choirId);
        }
      }

      // Choir-private custom songs
      match /songs/{songId} {
        allow read:  if isMemberOf(choirId) || isChoirOwner(choirId);
        allow write: if isDirectorOf(choirId) || isChoirOwner(choirId);
      }

      // Announcements
      match /announcements/{announcementId} {
        allow read:  if isMemberOf(choirId) || isChoirOwner(choirId);
        allow write: if isDirectorOf(choirId) || isChoirOwner(choirId);
      }

      // In-app notifications — any member may create one (e.g. substitution,
      // voice-part request); recipients read/update their own.
      match /notifications/{notificationId} {
        allow read:   if isMemberOf(choirId) &&
                         (resource.data.userId == request.auth.uid || isDirectorOf(choirId));
        allow create: if isMemberOf(choirId);
        allow update: if isMemberOf(choirId) && resource.data.userId == request.auth.uid;
        allow delete: if isDirectorOf(choirId);
      }

      // Voice-part change requests — members create their own; Directors read/update.
      match /voicePartRequests/{requestId} {
        allow read:   if isDirectorOf(choirId) ||
                         (isMemberOf(choirId) && resource.data.uid == request.auth.uid);
        allow create: if isMemberOf(choirId) && request.resource.data.uid == request.auth.uid;
        allow update: if isDirectorOf(choirId);
      }

      // Channels — visibility and posting respect visibleTo + directorOnly flags.
      match /channels/{channelId} {
        allow read:   if (isMemberOf(choirId) || isChoirOwner(choirId))
                      && (isChoirOwner(choirId) || canSeeChannel(resource.data));
        allow create: if isDirectorOf(choirId) || isChoirOwner(choirId);
        allow update: if isDirectorOf(choirId) || isChoirOwner(choirId);
        allow delete: if isDirectorOf(choirId) || isChoirOwner(choirId);

        // Messages — visibility mirrors channel; authorId must match caller; directorOnly enforced.
        match /messages/{messageId} {
          allow read:   if (isMemberOf(choirId) || isChoirOwner(choirId))
                        && (isChoirOwner(choirId) || canSeeChannel(
                              get(/databases/$(database)/documents/choirs/$(choirId)/channels/$(channelId)).data));
          allow create: if (isMemberOf(choirId) || isChoirOwner(choirId))
                        && request.resource.data.authorId == request.auth.uid
                        && (isChoirOwner(choirId) || canPostToChannel(
                              get(/databases/$(database)/documents/choirs/$(choirId)/channels/$(channelId)).data));
          // Any member who can see the channel may update reactions and thread
          // counters on others' messages; full edits remain author/director only.
          allow update: if (isMemberOf(choirId) && resource.data.authorId == request.auth.uid)
                        || isDirectorOf(choirId) || isChoirOwner(choirId)
                        || (isMemberOf(choirId)
                            && canSeeChannel(
                                 get(/databases/$(database)/documents/choirs/$(choirId)/channels/$(channelId)).data)
                            && request.resource.data.diff(resource.data).affectedKeys()
                              .hasOnly(['reactions', 'threadCount', 'threadLastReplyAt']));
          allow delete: if (isMemberOf(choirId) && resource.data.authorId == request.auth.uid)
                        || isDirectorOf(choirId) || isChoirOwner(choirId);
        }

        // Typing indicators — ephemeral presence docs, one per user. Writable
        // only by users who could post to the channel.
        match /typing/{userId} {
          allow read:   if isMemberOf(choirId) || isChoirOwner(choirId);
          allow write:  if (isMemberOf(choirId) || isChoirOwner(choirId))
                        && request.auth.uid == userId
                        && (isChoirOwner(choirId) || canPostToChannel(
                              get(/databases/$(database)/documents/choirs/$(choirId)/channels/$(channelId)).data));
        }
      }

      // Practice notes — each member owns their own notes.
      match /practiceNotes/{noteId} {
        allow read:   if isMemberOf(choirId) &&
                         noteId.matches(request.auth.uid + '_.*');
        allow write:  if isMemberOf(choirId) &&
                         noteId.matches(request.auth.uid + '_.*');
      }

      // Per-choir song overrides — directors set keys, lock, archive.
      match /songOverrides/{songId} {
        allow read:  if isMemberOf(choirId) || isChoirOwner(choirId);
        allow write: if isDirectorOf(choirId) || isChoirOwner(choirId);
      }

      // Suggestion feedback — members record accept/reject/replace events.
      match /suggestionFeedback/{feedbackId} {
        allow read:  if isDirectorOf(choirId) || isChoirOwner(choirId);
        allow create: if isMemberOf(choirId);
      }
    }

    // ── Users — offline song markers ───────────────────────────────────────────
    match /users/{uid}/offlineSongs/{songId} {
      allow read:  if isSignedIn() && isOwner(uid);
      allow write: if isSignedIn() && isOwner(uid);
    }

    // ── Global song library (read-only for authenticated users) ───────────────
    match /songs/{songId} {
      allow read:  if isSignedIn();
      allow write: if false; // seeded via admin SDK only
    }

    // ── Translation cache (server-written, clients read) ─────────────────────
    match /songTranslationCache/{cacheKey} {
      allow read:  if isSignedIn();
      allow write: if false; // written by Cloud Functions only
    }

    // ── Translation usage counters (server-only) ────────────────────────────
    match /translationUsage/{key} {
      allow read, write: if false; // Cloud Functions only
    }

    // ── Integration caches (Spotify / Genius) ─────────────────────────────────
    // Cloud Functions own these; clients may read and mirror cache entries to
    // avoid repeat lookups. No secrets are ever stored here.
    match /spotifyCache/{key} {
      allow read:   if isSignedIn();
      allow create, update: if isSignedIn();
    }
    match /geniusCache/{key} {
      allow read:   if isSignedIn();
      allow create, update: if isSignedIn();
    }
    match /geniusInfoCache/{key} {
      allow read:   if isSignedIn();
      allow create, update: if isSignedIn();
    }
    match /lyricsCache/{key} {
      allow read:   if isSignedIn();
      allow create, update: if isSignedIn();
    }
    match /chordsCache/{key} {
      allow read:   if isSignedIn();
      allow create, update: if isSignedIn();
    }
    match /songContextCache/{key} {
      allow read:   if isSignedIn();
      allow create, update: if isSignedIn();
    }
  }
}
