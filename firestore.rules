rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function getUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isMemberOf(choirId) {
      return isSignedIn() && getUser().choirId == choirId;
    }

    function isLeaderOf(choirId) {
      return isMemberOf(choirId) &&
        (getUser().role == 'owner' || getUser().role == 'leader');
    }

    // The user who owns the choir document (used during choir creation
    // before the user doc has been updated with choirId)
    function isChoirOwner(choirId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/choirs/$(choirId)).data.ownerId == request.auth.uid;
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if isSignedIn() && isOwner(uid);
      allow create: if isSignedIn() && isOwner(uid);
      allow update: if isSignedIn() && isOwner(uid);
    }

    // ── Choirs ────────────────────────────────────────────────────────────────
    match /choirs/{choirId} {
      allow read:   if isMemberOf(choirId) || isChoirOwner(choirId);
      allow create: if isSignedIn();
      allow update: if isLeaderOf(choirId) || isChoirOwner(choirId);
      allow delete: if isLeaderOf(choirId) || isChoirOwner(choirId);

      match /setlists/{setListId} {
        allow read:   if isMemberOf(choirId) || isChoirOwner(choirId);
        allow write:  if isLeaderOf(choirId) || isChoirOwner(choirId);
      }

      match /songs/{songId} {
        allow read:   if isMemberOf(choirId) || isChoirOwner(choirId);
        allow write:  if isLeaderOf(choirId) || isChoirOwner(choirId);
      }

      match /announcements/{announcementId} {
        allow read:   if isMemberOf(choirId) || isChoirOwner(choirId);
        allow write:  if isLeaderOf(choirId) || isChoirOwner(choirId);
      }

      match /events/{eventId} {
        allow read:   if isMemberOf(choirId) || isChoirOwner(choirId);
        allow write:  if isLeaderOf(choirId) || isChoirOwner(choirId);
      }

      match /availability/{docId} {
        allow read:   if isMemberOf(choirId) || isChoirOwner(choirId);
        allow create: if isMemberOf(choirId) || isChoirOwner(choirId);
        allow update: if (isMemberOf(choirId) || isChoirOwner(choirId)) &&
                         resource.data.userId == request.auth.uid;
      }

      // Members — owner can always write (needed during choir creation)
      match /members/{memberId} {
        allow read:   if isMemberOf(choirId) || isChoirOwner(choirId);
        allow write:  if isLeaderOf(choirId) || isChoirOwner(choirId);
      }
    }
  }
}
